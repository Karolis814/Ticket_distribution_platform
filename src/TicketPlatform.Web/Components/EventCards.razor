@inherits EventCardsBase

@if (IsLoading)
{
    <RadzenRow>
        @for (var i = 0; i < Size; i++)
        {
            <RadzenColumn Size="@ColSizeSm" SizeMd="@ColSizeMd" SizeLg="@ColSizeLg" Class="rz-mb-4">
                <RadzenCard Style="height:480px"
                            Class="rz-display-flex rz-align-items-center rz-justify-content-center">
                    <RadzenProgressBarCircular ShowValue="false"
                                               Mode="ProgressBarMode.Indeterminate"
                                               Size="ProgressBarCircularSize.Small"/>
                </RadzenCard>
            </RadzenColumn>
        }
    </RadzenRow>
}
else if (!Events.Any())
{
    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
        No events are currently available. Check back soon!
    </RadzenAlert>
}
else
{
    <RadzenRow>
        @foreach (var ev in Events)
        {
            <RadzenColumn Size="@ColSizeSm" SizeMd="@ColSizeMd" SizeLg="@ColSizeLg" Class="rz-mb-4">
                <RadzenCard Style="height:100%;display:flex;flex-direction:column;padding:0;overflow:hidden;">
                    <RadzenImage Path="@(ev.ThumbnailUrl ?? "https://placehold.net/8.png")"
                                 Style="width:100%;height:200px;object-fit:cover;"
                                 Click="@(() => NavigateToCheckout(ev.Id))"/>

                    <RadzenStack Gap="1rem" Class="rz-p-4" Style="flex-grow:1;">
                        <RadzenStack Orientation="Orientation.Horizontal"
                                     JustifyContent="JustifyContent.SpaceBetween"
                                     AlignItems="AlignItems.Center">
                            <RadzenBadge BadgeStyle="BadgeStyle.Info" IsPill="true" Text="@(ev.Category)"/>
                        </RadzenStack>

                        <RadzenText TextStyle="TextStyle.H6"
                                    TagName="TagName.H2"
                                    Style="margin:0;line-height:1.3;font-weight:bold;">
                            @ev.Title
                        </RadzenText>

                        <RadzenText TextStyle="TextStyle.Body2" Style="margin:0;">
                            @GetDescriptionExcerpt(ev.Description)
                        </RadzenText>

                        <RadzenStack Gap="0.5rem">
                            @if (!string.IsNullOrWhiteSpace(ev.Location))
                            {
                                <RadzenStack Orientation="Orientation.Horizontal"
                                             AlignItems="AlignItems.Center"
                                             Gap="0.5rem">
                                    <RadzenIcon Icon="location_on" class="rz-color-base-700"/>
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-base-700">
                                        @ev.Location
                                    </RadzenText>
                                </RadzenStack>
                            }

                            <RadzenStack Orientation="Orientation.Horizontal"
                                         AlignItems="AlignItems.Center"
                                         Gap="0.5rem">
                                <RadzenIcon Icon="calendar_today" class="rz-color-base-700"/>
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-color-base-700">
                                    @StartDate(ev).ToString("yyyy-MM-dd")
                                    @if (StartDate(ev).Date == EndDate(ev).Date)
                                    {
                                        <span>• @StartDate(ev).ToString("HH:mm") – @EndDate(ev).ToString("HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span> – @EndDate(ev).ToString("yyyy-MM-dd")</span>
                                    }
                                </RadzenText>
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenStack>

                    <div class="rz-p-4">
                        @if (ev.Status == EventStatus.Cancelled)
                        {
                            <RadzenButton Text="Canceled"
                                          ButtonStyle="ButtonStyle.Base"
                                          Style="width:100%"
                                          Disabled="true"/>
                        }
                        else if (RemainingTickets(ev) <= 0)
                        {
                            <RadzenButton Text="Sold Out"
                                          ButtonStyle="ButtonStyle.Secondary"
                                          Style="width:100%"
                                          Disabled="true"/>
                        }
                        else
                        {
                            <RadzenButton Text="@GetStartingPriceText(ev)"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Icon="confirmation_number"
                                          Click="@(() => NavigateToCheckout(ev.Id))"
                                          Style="width:100%"/>
                        }
                    </div>
                </RadzenCard>
            </RadzenColumn>
        }
    </RadzenRow>
}
