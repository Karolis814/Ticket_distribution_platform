@if (!string.IsNullOrEmpty(Url))
{
    <img src="@Url" alt="@Alt"
         style="width:100%;aspect-ratio:16/9;object-fit:cover;display:block;@Style"/>
}
else
{
    <div style="width:100%;aspect-ratio:16/9;background:linear-gradient(135deg,#1a237e 0%,#283593 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.4rem;@Style">
        <RadzenIcon Icon="confirmation_number" Style="font-size:2.5rem;color:rgba(255,255,255,0.2);"/>
        <span style="color:rgba(255,255,255,0.35);font-size:0.8rem;letter-spacing:0.04em;">No poster</span>
    </div>
}

@code {
    [Parameter] public string? Url { get; set; }
    [Parameter] public string Alt { get; set; } = "Event poster";
    [Parameter] public string Style { get; set; } = "";
}
