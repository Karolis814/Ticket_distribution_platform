@page "/user/settings"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inherits SettingsBase

<PageTitle>Settings</PageTitle>

<RadzenStack Gap="1.5rem" Style="max-width: 720px;">
    <PageHeader Title="Settings" Subtitle="Manage your account, profile, and payment settings." />

    @if (IsLoading)
    {
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else if (UserSettings is not null)
    {
        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H6">Stripe / Payments</RadzenText>

                @if (!string.IsNullOrWhiteSpace(StripeError))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">@StripeError</RadzenAlert>
                }

                @if (StripeStatus is null || string.IsNullOrWhiteSpace(StripeStatus.StripeAccountId))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
                        Stripe is not connected. Connect Stripe before creating events.
                    </RadzenAlert>

                    <RadzenButton Text="@(Connecting ? "Connecting…" : "Connect Stripe")"
                                  Icon="account_balance"
                                  ButtonStyle="ButtonStyle.Warning"
                                  Disabled="@Connecting"
                                  Click="@ConnectStripeAsync" />
                }
                else if (!StripeStatus.Ready)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
                        Stripe account connected but onboarding is incomplete. Continue setup to start accepting payments.
                    </RadzenAlert>

                    <RadzenButton Text="@(Connecting ? "Connecting…" : "Continue Stripe setup")"
                                  Icon="account_balance"
                                  ButtonStyle="ButtonStyle.Warning"
                                  Disabled="@Connecting"
                                  Click="@ConnectStripeAsync" />

                    @if (PollingStripe)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color)">
                                Checking status in @StripeCountdown s…
                            </RadzenText>
                        </RadzenStack>
                    }
                }
                else
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true">
                        Stripe is connected and ready.
                    </RadzenAlert>
                }
            </RadzenStack>
        </RadzenCard>

        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H6">Profile</RadzenText>

                <RadzenFormField Text="Email" Variant="Variant.Outlined" Style="width:100%">
                    <RadzenTextBox Value="@UserSettings.Email" Disabled="true" Style="width:100%" />
                </RadzenFormField>

                <RadzenRow Gap="0.75rem">
                    <RadzenColumn Size="12" SizeSm="6">
                        <RadzenFormField Text="First name" Variant="Variant.Outlined" Style="width:100%">
                            <RadzenTextBox @bind-Value="FirstName" Style="width:100%" />
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeSm="6">
                        <RadzenFormField Text="Last name" Variant="Variant.Outlined" Style="width:100%">
                            <RadzenTextBox @bind-Value="LastName" Style="width:100%" />
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenFormField Text="Phone number" Variant="Variant.Outlined" Style="width:100%">
                    <RadzenTextBox @bind-Value="PhoneNumber" Style="width:100%" />
                </RadzenFormField>

                <RadzenFormField Text="Company" Variant="Variant.Outlined" Style="width:100%">
                    <RadzenTextBox @bind-Value="Company" Style="width:100%" />
                </RadzenFormField>

                <RadzenFormField Text="Address" Variant="Variant.Outlined" Style="width:100%">
                    <RadzenTextBox @bind-Value="Address" Style="width:100%" />
                </RadzenFormField>

                <RadzenFormField Text="Tax / Company ID" Variant="Variant.Outlined" Style="width:100%">
                    <RadzenTextBox @bind-Value="TaxCode" Style="width:100%" />
                </RadzenFormField>

                <RadzenButton Text="Save profile"
                              ButtonStyle="ButtonStyle.Primary"
                              Click="@SaveProfileAsync" />
            </RadzenStack>
        </RadzenCard>

        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H6">Password</RadzenText>

                <RadzenPassword @bind-Value="CurrentPassword"
                                Placeholder="Current password"
                                Style="width:100%" />

                <RadzenPassword @bind-Value="NewPassword"
                                Placeholder="New password"
                                Style="width:100%" />

                <RadzenButton Text="Change password"
                              ButtonStyle="ButtonStyle.Primary"
                              Click="@ChangePasswordAsync" />
            </RadzenStack>
        </RadzenCard>

        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H6" Style="color: var(--rz-danger)">Danger zone</RadzenText>

                @if (!ConfirmDelete)
                {
                    <RadzenButton Text="Delete account"
                                  Icon="delete_forever"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Variant="Variant.Outlined"
                                  Click="@(() => ConfirmDelete = true)" />
                }
                else
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">
                        This will permanently delete your account and all associated data. This cannot be undone.
                    </RadzenAlert>
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem">
                        <RadzenButton Text="Yes, delete my account"
                                      Icon="delete_forever"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Click="@DeleteAccountAsync" />
                        <RadzenButton Text="Cancel"
                                      ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => ConfirmDelete = false)" />
                    </RadzenStack>
                }
            </RadzenStack>
        </RadzenCard>
    }
</RadzenStack>

