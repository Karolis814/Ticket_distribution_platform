@page "/payment-success"
@using System.Net.Http.Json
@using TicketPlatform.Shared.Dtos
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Payment successful</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" Class="rz-mt-8">
    <RadzenColumn Size="12" SizeMd="7" SizeLg="5">
        <RadzenCard>
            <RadzenStack Gap="1rem">

                <RadzenText TextStyle="TextStyle.H4" Style="font-weight:700">
                    Payment successful
                </RadzenText>

                <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true">
                    Tickets were sent to your email.
                </RadzenAlert>

                @if (Loading)
                {
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                    <RadzenText TextStyle="TextStyle.Body2">
                        Loading invoice information...
                    </RadzenText>
                }
                else if (!string.IsNullOrWhiteSpace(Error))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
                        @Error
                    </RadzenAlert>

                    <RadzenButton Text="Try again"
                                  Icon="refresh"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Click="LoadPayment"
                                  Style="width:100%" />
                }
                else if (Payment is not null)
                {
                    <RadzenText TextStyle="TextStyle.Body1">
                        Your tickets were sent to:
                        <strong>@Payment.Email</strong>
                    </RadzenText>

                    @if (Payment.InvoiceReady && !string.IsNullOrWhiteSpace(Payment.InvoicePdfUrl))
                    {
                        <RadzenButton Text="Download invoice PDF"
                                      Icon="download"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Click="@(() => Nav.NavigateTo(Payment.InvoicePdfUrl!, forceLoad: true))"
                                      Style="width:100%" />
                    }

                    @if (Payment.InvoiceReady && !string.IsNullOrWhiteSpace(Payment.InvoiceUrl))
                    {
                        <RadzenButton Text="View invoice"
                                      Icon="receipt_long"
                                      ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => Nav.NavigateTo(Payment.InvoiceUrl!, forceLoad: true))"
                                      Style="width:100%" />
                    }

                    @if (!Payment.InvoiceReady)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
                            Invoice is still being generated. Refresh in a few seconds.
                        </RadzenAlert>

                        <RadzenButton Text="Refresh invoice"
                                      Icon="refresh"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Click="LoadPayment"
                                      Style="width:100%" />
                    }
                }

                <RadzenButton Text="Back to events"
                              Icon="event"
                              ButtonStyle="ButtonStyle.Light"
                              Click="@(() => Nav.NavigateTo("/events"))"
                              Style="width:100%" />

            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    private PaymentSuccessDto? Payment { get; set; }
    private bool Loading { get; set; } = true;
    private string? Error { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadPayment();
    }

    private async Task LoadPayment()
    {
        Loading = true;
        Error = null;

        try
        {
            var uri = Nav.ToAbsoluteUri(Nav.Uri);

            var sessionId =
                System.Web.HttpUtility.ParseQueryString(uri.Query)
                    .Get("session_id");

            if (string.IsNullOrWhiteSpace(sessionId))
            {
                Error = "Missing Stripe session id.";
                return;
            }

            var response = await Http.GetAsync(
                $"api/payments/success?sessionId={Uri.EscapeDataString(sessionId)}");

            if (!response.IsSuccessStatusCode)
            {
                Error = await response.Content.ReadAsStringAsync();
                return;
            }

            Payment = await response.Content.ReadFromJsonAsync<PaymentSuccessDto>();
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }
}
