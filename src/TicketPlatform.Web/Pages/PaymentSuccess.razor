@page "/payment-success"
@inherits PaymentSuccessBase

<PageTitle>Payment successful</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" Class="rz-mt-8">
    <RadzenColumn Size="12" SizeMd="7" SizeLg="5">
        <RadzenCard>
            <RadzenStack Gap="1rem">

                <RadzenText TextStyle="TextStyle.H4" Style="font-weight:700">
                    Payment successful
                </RadzenText>

                <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true">
                    Tickets were sent to your email.
                </RadzenAlert>

                @if (Loading)
                {
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                    <RadzenText TextStyle="TextStyle.Body2">
                        Loading payment information...
                    </RadzenText>
                }
                else if (!string.IsNullOrWhiteSpace(Error))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
                        @Error
                    </RadzenAlert>

                    <RadzenButton Text="Try again"
                                  Icon="refresh"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Click="LoadPayment"
                                  Style="width:100%" />
                }
                else if (Payment is not null)
                {
                    <RadzenText TextStyle="TextStyle.Body1">
                        Your tickets were sent to:
                        <strong>@Payment.Email</strong>
                    </RadzenText>

                    <RadzenButton Text="Download tickets"
                                  Icon="download"
                                  ButtonStyle="ButtonStyle.Success"
                                  Click="@(() => Nav.NavigateTo(DownloadTicketsUrl, forceLoad: true))"
                                  Style="width:100%" />

                    @if (Payment.InvoiceReady && !string.IsNullOrWhiteSpace(Payment.InvoicePdfUrl))
                    {
                        <RadzenButton Text="Download invoice PDF"
                                      Icon="receipt"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Click="@(() => Nav.NavigateTo(Payment.InvoicePdfUrl!, forceLoad: true))"
                                      Style="width:100%" />
                    }

                    @if (Payment.InvoiceReady && !string.IsNullOrWhiteSpace(Payment.InvoiceUrl))
                    {
                        <RadzenButton Text="View invoice"
                                      Icon="receipt_long"
                                      ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => Nav.NavigateTo(Payment.InvoiceUrl!, forceLoad: true))"
                                      Style="width:100%" />
                    }

                    @if (!Payment.InvoiceReady && _polling)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
                            Invoice is being generated...
                        </RadzenAlert>
                        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
                    }

                    @if (!Payment.InvoiceReady && !_polling)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
                            Invoice is still being generated — check your email shortly.
                        </RadzenAlert>
                    }
                }

                <RadzenButton Text="Back to events"
                              Icon="event"
                              ButtonStyle="ButtonStyle.Light"
                              Click="@(() => Nav.NavigateTo("/events"))"
                              Style="width:100%" />

            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
