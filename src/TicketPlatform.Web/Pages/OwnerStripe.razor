@page "/owner/stripe/{HostId:guid}"
@inherits OwnerStripeBase

<PageTitle>Stripe settings</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" Class="rz-mt-8">
    <RadzenColumn Size="12" SizeMd="7" SizeLg="5">
        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H4" Style="font-weight:700">
                    Stripe payments
                </RadzenText>

                @if (Loading)
                {
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace(Error))
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">
                            @Error
                        </RadzenAlert>
                    }

                    @if (Status is null || !Status.Ready)
                    {
                        @if (Status is not null && !string.IsNullOrWhiteSpace(Status.StripeAccountId))
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
                                Stripe account connected but setup is incomplete:
                                @if (!Status.DetailsSubmitted)
                                {
                                    <div>— Details not yet submitted</div>
                                }
                                @if (!Status.ChargesEnabled)
                                {
                                    <div>— Charges not yet enabled by Stripe</div>
                                }
                                @if (!Status.PayoutsEnabled)
                                {
                                    <div>— Payouts not yet enabled by Stripe</div>
                                }
                            </RadzenAlert>

                            <RadzenButton Text="Continue Stripe setup"
                                          Icon="account_balance"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Click="ConnectStripe"
                                          Disabled="_connecting"
                                          Style="width:100%" />
                        }
                        else
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
                                Stripe is not connected. Connect Stripe to receive ticket payments.
                            </RadzenAlert>

                            <RadzenButton Text="Connect Stripe"
                                          Icon="account_balance"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Click="ConnectStripe"
                                          Disabled="_connecting"
                                          Style="width:100%" />
                        }
                    }
                    else
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true">
                            Stripe is connected and ready to receive payments.
                        </RadzenAlert>
                    }
                }

                <RadzenButton Text="Back to events"
                              Icon="arrow_back"
                              ButtonStyle="ButtonStyle.Light"
                              Click="@(() => Nav.NavigateTo("/events"))"
                              Style="width:100%" />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
