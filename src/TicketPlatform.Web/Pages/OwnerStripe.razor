@page "/owner/stripe/{HostId:guid}"
@using System.Net.Http.Json
@using TicketPlatform.Shared.Dtos
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Stripe settings</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" Class="rz-mt-8">
    <RadzenColumn Size="12" SizeMd="7" SizeLg="5">
        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H4" Style="font-weight:700">
                    Stripe payments
                </RadzenText>

                @if (Loading)
                {
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                }
                else if (Status is null || !Status.Ready)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
                        Stripe is not fully connected. Connect Stripe to receive ticket payments.
                    </RadzenAlert>

                    <RadzenButton Text="Connect Stripe"
                                  Icon="account_balance"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Click="ConnectStripe"
                                  Style="width:100%" />
                }
                else
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true">
                        Stripe is connected and ready to receive payments.
                    </RadzenAlert>
                }

                <RadzenButton Text="Back to events"
                              Icon="arrow_back"
                              ButtonStyle="ButtonStyle.Light"
                              Click="@(() => Nav.NavigateTo("/events"))"
                              Style="width:100%" />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    [Parameter] public Guid HostId { get; set; }

    private StripeConnectStatusDto? Status { get; set; }
    private bool Loading { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadStatus();
    }

    private async Task LoadStatus()
    {
        Loading = true;

        try
        {
            Status = await Http.GetFromJsonAsync<StripeConnectStatusDto>(
                $"api/stripe-connect/status/{HostId}");
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task ConnectStripe()
    {
        var response = await Http.PostAsync(
            $"api/stripe-connect/onboard/{HostId}",
            null);

        response.EnsureSuccessStatusCode();

        var result = await response.Content.ReadFromJsonAsync<StripeConnectLinkResponse>();

        if (!string.IsNullOrWhiteSpace(result?.Url))
            Nav.NavigateTo(result.Url, forceLoad: true);
    }

    private sealed record StripeConnectLinkResponse(string Url);
}
