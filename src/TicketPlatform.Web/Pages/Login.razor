@page "/auth/login"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inherits LoginBase

<PageTitle>Sign In</PageTitle>

<RadzenCard Style="width:100%;max-width:420px;margin:2rem auto;">

    <EditForm Model="@Model" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator/>

        <RadzenStack Gap="1.5rem">

            <PageHeader Title="Sign In" Subtitle="Welcome back."/>

            @if (ErrorMessage is not null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false">
                    @ErrorMessage
                </RadzenAlert>
            }

            <RadzenStack Gap="1rem">

                <RadzenStack Gap="0.25rem">
                    <RadzenFormField Text="Email address" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenTextBox @bind-Value="Model.Email"
                                       Placeholder="you@example.com"
                                       InputType="InputType.Email"
                                       Style="width:100%"/>
                    </RadzenFormField>
                    <ValidationMessage For="@(() => Model.Email)"/>
                </RadzenStack>

                <RadzenStack Gap="0.25rem">
                    <RadzenFormField Text="Password" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenPassword @bind-Value="Model.Password"
                                        Placeholder="••••••••"
                                        Style="width:100%"/>
                    </RadzenFormField>
                    <ValidationMessage For="@(() => Model.Password)"/>
                </RadzenStack>

            </RadzenStack>

            <RadzenStack Gap="0.75rem">
                <RadzenButton Text="@(IsLoading ? "Signing In…" : "Sign In")"
                              ButtonType="ButtonType.Submit"
                              ButtonStyle="ButtonStyle.Primary"
                              Size="ButtonSize.Large"
                              Icon="@(IsLoading ? "" : "login")"
                              Disabled="@IsLoading"
                              Style="width:100%"/>

                <RadzenButton Text="Create Account"
                              ButtonStyle="ButtonStyle.Secondary"
                              Size="ButtonSize.Large"
                              Icon="@("person_add")"
                              Style="width:100%"
                              Click="@(() => Nav.NavigateTo("/auth/register"))"/>
            </RadzenStack>

            <RadzenText TextStyle="TextStyle.Body2" Style="text-align:center;margin:0">
                <RadzenLink Path="/auth/forgot-password" Text="Forgot Password?"/>
            </RadzenText>

        </RadzenStack>

    </EditForm>

</RadzenCard>
