@page "/auth/login"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inherits LoginBase

<PageTitle>Sign in</PageTitle>

<RadzenCard Style="max-width:420px;margin:2rem auto;">

    <RadzenStack Gap="1.5rem">

        <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" Style="margin:0">
            Sign in
        </RadzenText>

        @if (ErrorMessage is not null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false">
                @ErrorMessage
            </RadzenAlert>
        }

        <RadzenStack Gap="1rem">

            <RadzenFormField Text="Email address" Variant="Variant.Outlined" Style="width:100%">
                <RadzenTextBox @bind-Value="Model.Email"
                               Placeholder="you@example.com"
                               InputType="InputType.Email"
                               Style="width:100%" />
            </RadzenFormField>

            <RadzenFormField Text="Password" Variant="Variant.Outlined" Style="width:100%">
                <RadzenPassword @bind-Value="Model.Password"
                                Placeholder="••••••••"
                                Style="width:100%" />
            </RadzenFormField>

        </RadzenStack>

        <RadzenButton Text="@(IsLoading ? "Signing in…" : "Sign in")"
                      ButtonStyle="ButtonStyle.Primary"
                      Size="ButtonSize.Large"
                      Icon="@(IsLoading ? "" : "login")"
                      Disabled="@IsLoading"
                      Click="HandleLogin"
                      Style="width:100%" />

        <RadzenText TextStyle="TextStyle.Body2" Style="text-align:center;margin:0">
            Don't have an account?
            <RadzenLink Path="/auth/register" Text="Register" />
        </RadzenText>

    </RadzenStack>

</RadzenCard>
