@page "/owner/stripe/return/{HostId:guid}"
@inject NavigationManager Nav

<RadzenRow JustifyContent="JustifyContent.Center" Class="rz-mt-8">
    <RadzenColumn Size="12" SizeMd="7" SizeLg="5">
        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true">
                    Stripe onboarding completed. We are checking your account status.
                </RadzenAlert>

                <RadzenButton Text="Continue"
                              ButtonStyle="ButtonStyle.Primary"
                              Click="@(() => Nav.NavigateTo($"/owner/stripe/{HostId}"))" />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    [Parameter] public Guid HostId { get; set; }
}
