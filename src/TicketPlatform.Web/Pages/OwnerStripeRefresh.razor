@page "/stripe/refresh/{HostId:guid}"

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Host")]
@inherits OwnerStripeRefreshBase

<RadzenRow JustifyContent="JustifyContent.Center" Class="rz-mt-8">
    <RadzenColumn Size="12" SizeMd="7" SizeLg="5">
        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
                    Stripe onboarding link expired. Please start onboarding again.
                </RadzenAlert>

                <RadzenButton Text="Reconnect Stripe"
                              ButtonStyle="ButtonStyle.Primary"
                              Icon="refresh"
                              Size="ButtonSize.Large"
                              Click="GoToSettings" />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
