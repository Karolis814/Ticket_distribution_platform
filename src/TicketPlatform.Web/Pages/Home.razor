@page "/"
@inherits HomeBase

<PageTitle>Ticket Platform</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" Class="rz-mt-12">
    <RadzenColumn Size="12" SizeMd="8" SizeLg="5">
        <RadzenStack Gap="1.5rem" AlignItems="AlignItems.Center">

            <RadzenIcon Icon="confirmation_number" Style="font-size:4rem;"/>

            <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" TextAlign="TextAlign.Center">
                Welcome to the Ticket Distribution Platform
            </RadzenText>

            <RadzenText TextStyle="TextStyle.Body1" TextAlign="TextAlign.Center">
                Browse upcoming events and grab your tickets without any fuss!
            </RadzenText>

            <RadzenButton Text="Browse Events"
                          Icon="event"
                          ButtonStyle="ButtonStyle.Primary"
                          Size="ButtonSize.Large"
                          Click="@(() => Nav.NavigateTo("/events"))"/>

            <RadzenButton Text="Create Event"
                          Icon="add_event"
                          ButtonStyle="ButtonStyle.Success"
                          Size="ButtonSize.Large"
                          Click="@(() => Nav.NavigateTo("/createEvent"))"/>

        </RadzenStack>
    </RadzenColumn>
</RadzenRow>
