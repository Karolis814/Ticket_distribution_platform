@page "/"


@inherits HomeBase

<PageTitle>Ticket Platform</PageTitle>

<RadzenRow Class="rz-mb-6">
    <RadzenColumn Size="12">
        @if (IsLoading)
        {
            <RadzenCard Style="min-height:320px"
                        Class="rz-display-flex rz-align-items-center rz-justify-content-center">
                <RadzenProgressBarCircular ShowValue="false"
                                           Mode="ProgressBarMode.Indeterminate"
                                           Size="ProgressBarCircularSize.Medium"/>
            </RadzenCard>
        }
        else if (TrendingEvents.Any())
        {
            <RadzenCarousel Auto="true"
                            Interval="5000"
                            AllowNavigation="true"
                            AllowPaging="true"
                            PagerPosition="PagerPosition.Bottom"
                            PagerOverlay="false">
                <Items>
                    @foreach (var ev in TrendingEvents)
                    {
                        <RadzenCarouselItem>
                            <RadzenCard Class="rz-overflow-hidden rz-p-0"
                                        style="width:100%;cursor:pointer;"
                                        @onclick="@(() => Nav.NavigateTo($"/events/{ev.Id}"))">
                                <div class="carousel-slide">
                                    <div class="carousel-slide-info">
                                        <div class="rz-mb-3">
                                            <RadzenBadge BadgeStyle="BadgeStyle.Info"
                                                         IsPill="true"
                                                         Text="@ev.Category.ToString()"/>
                                        </div>
                                        <RadzenText TextStyle="TextStyle.H6"
                                                    TagName="TagName.H3"
                                                    Class="rz-mb-2">
                                            @ev.Title
                                        </RadzenText>
                                        <RadzenText TextStyle="TextStyle.Body2"
                                                    Class="rz-mb-3"
                                                    Style="opacity:0.75;">
                                            @(ev.Description.Length > 150 ? ev.Description[..147] + "..." : ev.Description)
                                        </RadzenText>
                                        <RadzenStack Orientation="Orientation.Vertical"
                                                     Gap="0.4rem"
                                                     Class="rz-mb-4"
                                                     Style="width:100%;">
                                            @if (ev.TicketTypes.Any())
                                            {
                                                <RadzenStack Orientation="Orientation.Horizontal"
                                                             AlignItems="AlignItems.Center"
                                                             Gap="0.3rem">
                                                    <RadzenIcon Icon="calendar_today"/>
                                                    <RadzenText TextStyle="TextStyle.Body2">
                                                        @StartDate(ev).ToString("yyyy-MM-dd")
                                                        @if (StartDate(ev).Date == EndDate(ev).Date)
                                                        {
                                                            <span>&nbsp;@StartDate(ev).ToString("HH:mm")&nbsp;–&nbsp;@EndDate(ev).ToString("HH:mm")</span>
                                                        }
                                                        else
                                                        {
                                                            <span>&nbsp;–&nbsp;@EndDate(ev).ToString("yyyy-MM-dd")</span>
                                                        }
                                                    </RadzenText>
                                                </RadzenStack>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(ev.Location))
                                            {
                                                <RadzenStack Orientation="Orientation.Horizontal"
                                                             AlignItems="AlignItems.Center"
                                                             Gap="0.3rem">
                                                    <RadzenIcon Icon="location_on" Style="flex-shrink:0;"/>
                                                    <RadzenText TextStyle="TextStyle.Body2"
                                                                Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@ev.Location</RadzenText>
                                                </RadzenStack>
                                            }
                                        </RadzenStack>
                                        @if (ev.Status != EventStatus.Cancelled && RemainingTickets(ev) > 0 && GetMinPriceText(ev) is { } price)
                                        {
                                            <div class="rz-mb-4">
                                                <RadzenText TextStyle="TextStyle.Overline"
                                                            Class="rz-text-tertiary-color">Tickets from
                                                </RadzenText>
                                                <RadzenText TextStyle="TextStyle.H5">@price</RadzenText>
                                            </div>
                                        }
                                        @if (ev.Status == EventStatus.Cancelled)
                                        {
                                            <RadzenButton Text="Canceled"
                                                          ButtonStyle="ButtonStyle.Base"
                                                          Size="ButtonSize.Large"
                                                          Disabled="true"
                                                          @onclick:stopPropagation="true"/>
                                        }
                                        else if (RemainingTickets(ev) <= 0)
                                        {
                                            <RadzenButton Text="Sold Out"
                                                          ButtonStyle="ButtonStyle.Secondary"
                                                          Size="ButtonSize.Large"
                                                          Disabled="true"
                                                          @onclick:stopPropagation="true"/>
                                        }
                                        else
                                        {
                                            <RadzenButton Text="Get Tickets"
                                                          Icon="confirmation_number"
                                                          ButtonStyle="ButtonStyle.Primary"
                                                          Size="ButtonSize.Large"
                                                          Click="@(() => Nav.NavigateTo($"/events/{ev.Id}"))"
                                                          @onclick:stopPropagation="true"/>
                                        }
                                    </div>
                                    <div class="carousel-slide-poster">
                                        <EventPoster Url="@ev.ThumbnailUrl" Alt="@ev.Title"/>
                                    </div>
                                </div>
                            </RadzenCard>
                        </RadzenCarouselItem>
                    }
                </Items>
            </RadzenCarousel>
        }
    </RadzenColumn>
</RadzenRow>

<RadzenRow Class="rz-mb-6">
    <RadzenColumn Size="12">
        <RadzenStack Orientation="Orientation.Horizontal"
                     JustifyContent="JustifyContent.SpaceBetween"
                     AlignItems="AlignItems.Center"
                     Class="rz-mb-3">
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H2">
                Latest Events
            </RadzenText>
            <RadzenButton Text="View All"
                          Icon="arrow_forward"
                          ButtonStyle="ButtonStyle.Light"
                          Variant="Variant.Text"
                          Size="ButtonSize.Medium"
                          Click="@(() => Nav.NavigateTo("/events"))"/>
        </RadzenStack>

        <EventCards Events="LatestEvents" IsLoading="IsLoading"/>
    </RadzenColumn>
</RadzenRow>

<RadzenRow Class="rz-mb-6">
    <RadzenColumn Size="12">
        <RadzenStack Orientation="Orientation.Horizontal"
                     JustifyContent="JustifyContent.SpaceBetween"
                     AlignItems="AlignItems.Center"
                     Class="rz-mb-3">
            <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H2">
                Upcoming Events
            </RadzenText>
            <RadzenButton Text="View All"
                          Icon="arrow_forward"
                          ButtonStyle="ButtonStyle.Light"
                          Variant="Variant.Text"
                          Size="ButtonSize.Medium"
                          Click="@(() => Nav.NavigateTo("/events"))"/>
        </RadzenStack>

        <EventCards Events="UpcomingEvents" IsLoading="IsLoading"/>
    </RadzenColumn>
</RadzenRow>

<RadzenCard Class="rz-background-color-base-800 rz-py-12 rz-px-8 rz-mb-6">
    <RadzenStack Gap="1.5rem" AlignItems="AlignItems.Center">
        <RadzenIcon Icon="local_activity" Style="font-size:3rem;"/>
        <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H2" TextAlign="TextAlign.Center">
            Find Your Next Experience
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body1" TextAlign="TextAlign.Center" Style="max-width:520px;">
            Browse hundreds of events — concerts, sports, theatre, and more.
            Secure your tickets in seconds, no account required.
        </RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal"
                     Gap="1rem"
                     Style="flex-wrap:wrap;"
                     JustifyContent="JustifyContent.Center">
            <RadzenButton Text="View All Events"
                          Icon="event"
                          ButtonStyle="ButtonStyle.Primary"
                          Size="ButtonSize.Large"
                          Click="@(() => Nav.NavigateTo("/events"))"/>
            <RadzenButton Text="Search Events"
                          Icon="search"
                          ButtonStyle="ButtonStyle.Secondary"
                          Size="ButtonSize.Large"
                          Click="@(() => Nav.NavigateTo("/events"))"/>
            <RadzenButton Text="My Tickets"
                          Icon="confirmation_number"
                          ButtonStyle="ButtonStyle.Info"
                          Size="ButtonSize.Large"
                          Click="@(() => Nav.NavigateTo("/user/purchases"))"/>
        </RadzenStack>
    </RadzenStack>
</RadzenCard>

<RadzenCard Class="rz-background-color-base-800 rz-py-12 rz-px-8 rz-mb-4">
    <RadzenStack Gap="1.5rem" AlignItems="AlignItems.Center">
        <RadzenIcon Icon="storefront" Style="font-size:3rem;"/>
        <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H2" TextAlign="TextAlign.Center">
            Start Selling Tickets
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body1" TextAlign="TextAlign.Center" Style="max-width:520px;">
            Create and manage your events, set ticket types and pricing,
            and reach your audience with ease.
        </RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal"
                     Gap="1rem"
                     Style="flex-wrap:wrap;"
                     JustifyContent="JustifyContent.Center">
            <RadzenButton Text="Start Selling"
                          Icon="add_circle"
                          ButtonStyle="ButtonStyle.Primary"
                          Size="ButtonSize.Large"
                          Click="@(() => Nav.NavigateTo("/host/create"))"/>
        </RadzenStack>
    </RadzenStack>
</RadzenCard>
