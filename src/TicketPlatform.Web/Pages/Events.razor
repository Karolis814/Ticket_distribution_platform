@page "/events"

@inherits EventsBase

<PageTitle>Events</PageTitle>

<RadzenStack Gap="1rem">

    <PageHeader Title="Upcoming Events" Subtitle="Browse and grab your tickets below." />

    <RadzenCard Class="rz-p-4">
        <RadzenStack Gap="1rem">

            <RadzenStack Orientation="Orientation.Horizontal"
                         AlignItems="AlignItems.Center"
                         JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                    <RadzenIcon Icon="tune" Style="font-size:1rem;opacity:0.55;"/>
                    <RadzenText TextStyle="TextStyle.Overline" Style="margin:0;opacity:0.55;">Filters</RadzenText>
                </RadzenStack>
                @if (!string.IsNullOrWhiteSpace(SearchText) || FromDate.HasValue || !string.IsNullOrWhiteSpace(SelectedCategory) || !string.IsNullOrWhiteSpace(LocationText))
                {
                    <RadzenButton Text="Clear all" Icon="close" ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.ExtraSmall" Variant="Variant.Text"
                                  Click="@ClearFilterAsync" />
                }
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem"
                         AlignItems="AlignItems.Center" Style="flex-wrap:wrap;">

                <RadzenAutoComplete TValue="string"
                                    Data="@TitleSuggestions"
                                    @bind-Value="SearchText"
                                    Placeholder="Search title"
                                    Style="flex:1;min-width:150px;"
                                    MinLength="2"
                                    LoadData="@LoadTitleSuggestions" />

                <RadzenDatePicker @bind-Value="FromDate"
                                  Placeholder="From date"
                                  DateFormat="yyyy-MM-dd"
                                  Style="flex:1;min-width:150px;" />

                <RadzenDropDown TValue="string"
                                Data="@Categories"
                                @bind-Value="SelectedCategory"
                                Placeholder="Category"
                                Style="flex:1;min-width:130px;"
                                AllowClear="true" />

                <RadzenAutoComplete TValue="string"
                                    Data="@LocationSuggestions"
                                    @bind-Value="LocationText"
                                    Placeholder="Location"
                                    Style="flex:1;min-width:150px;"
                                    MinLength="2"
                                    LoadData="@LoadLocationSuggestions" />

                <RadzenButton Text="Search" Icon="search"
                              ButtonStyle="ButtonStyle.Primary"
                              Click="@ApplyFilterAsync" />

            </RadzenStack>

        </RadzenStack>
    </RadzenCard>

    <EventCards Events="Events" IsLoading="IsLoading" />

    @if (!IsLoading && (Result?.TotalCount ?? 0) > 0)
    {
        <RadzenPager Count="@(Result!.TotalCount)"
                     PageSize="@PageSize"
                     PageNumbersCount="5"
                     PageChanged="@OnPageChange" />
    }

</RadzenStack>
