@page "/events"

@inherits EventsBase

<PageTitle>Explore Events</PageTitle>

<RadzenStack Gap="1rem">

    <PageHeader Title="Upcoming Events" Subtitle="Browse and grab your tickets below.">
        <Actions>
            <RadzenButton Icon="tune" Text="Filters"
                          ButtonStyle="@(HasActiveFilters ? ButtonStyle.Primary : ButtonStyle.Secondary)" Click="@ToggleFilters"/>
        </Actions>
    </PageHeader>

    <EventCards Events="Events" IsLoading="IsLoading"/>

    @if (!IsLoading && Result != null)
    {
        <RadzenPager Count="@Result.TotalCount"
                     PageSize="@PageSize"
                     PageNumbersCount="5"
                     AlwaysVisible="true"
                     HorizontalAlign="HorizontalAlign.Left"
                     ShowPagingSummary="true"
                     PageChanged="@OnPageChange"/>
    }

</RadzenStack>

@if (FiltersOpen)
{
    <div class="filter-overlay" @onclick="ToggleFilters"></div>
}

<div class="filter-offcanvas @(FiltersOpen ? "open" : "")">

    <RadzenStack Gap="1.25rem" Style="height:100%;overflow-y:auto;">

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                <RadzenIcon Icon="tune" Style="font-size:1rem;opacity:0.6;"/>
                <RadzenText TextStyle="TextStyle.H6" Style="margin:0;">Filters</RadzenText>
            </RadzenStack>
            <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                          Size="ButtonSize.Small" Click="@ToggleFilters"/>
        </RadzenStack>

        <RadzenFormField Text="Title" Variant="Variant.Outlined" Style="width:100%;">
            <RadzenAutoComplete Name="EventTitle" TValue="string"
                                Data="@TitleSuggestions"
                                @bind-Value="SearchText"
                                Placeholder="Search by title…"
                                MinLength="2"
                                LoadData="@LoadTitleSuggestions"
                                Style="width:100%;"/>
        </RadzenFormField>

        <RadzenFormField Text="From Date" Variant="Variant.Outlined" Style="width:100%;">
            <RadzenDatePicker Name="FromDate" @bind-Value="FromDate"
                              Placeholder="Any date"
                              DateFormat="yyyy-MM-dd"
                              Style="width:100%;"/>
        </RadzenFormField>

        <RadzenFormField Text="Category" Variant="Variant.Outlined" Style="width:100%;">
            <RadzenDropDown Name="Category" TValue="string"
                            Data="@Categories"
                            @bind-Value="SelectedCategory"
                            Placeholder="All categories"
                            AllowClear="true"
                            Style="display:block;width:100%;"/>
        </RadzenFormField>

        <RadzenFormField Text="Location" Variant="Variant.Outlined" Style="width:100%;">
            <RadzenAutoComplete Name="Location" TValue="string"
                                Data="@LocationSuggestions"
                                @bind-Value="LocationText"
                                Placeholder="Search by location…"
                                MinLength="2"
                                LoadData="@LoadLocationSuggestions"
                                Style="width:100%;"/>
        </RadzenFormField>

        <RadzenStack Gap="0.5rem" Style="margin-top:auto;margin-bottom:3rem;">
            <RadzenButton Text="Apply" Icon="filter_list" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large"
                          Style="width:100%;" Click="@ApplyFilterAsync"/>
            @if (HasActiveFilters)
            {
                <RadzenButton Text="Clear all" Icon="close" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Large"
                              Style="width:100%;" Click="@ClearFilterAsync"/>
            }
        </RadzenStack>

    </RadzenStack>

</div>
