@page "/auth/register"
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations
@attribute [AllowAnonymous]
@inherits RegisterBase

<PageTitle>Create account</PageTitle>

<RadzenCard Style="max-width:560px;margin:2rem auto;">

    <RadzenStack Gap="1.5rem">

        <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" Style="margin:0">
            Create account
        </RadzenText>

        @if (ErrorMessage is not null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false">
                @ErrorMessage
            </RadzenAlert>
        }

        <EditForm EditContext="EditContext" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />

        <RadzenStack Gap="1rem">

            <RadzenText TextStyle="TextStyle.Overline" Style="margin:0">
                Account details
            </RadzenText>

            <RadzenFormField Text="Email address *" Variant="Variant.Outlined" Style="width:100%">
                <RadzenTextBox @bind-Value="Email"
                               Placeholder="you@example.com"
                               InputType="InputType.Email"
                               Style="width:100%" />
            </RadzenFormField>
            <ValidationMessage For="@(() => Email)" />

            <RadzenRow Gap="0.75rem">
                <RadzenColumn Size="12" SizeSm="6">
                    <RadzenFormField Text="Password *" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenPassword @bind-Value="Password"
                                        Placeholder="••••••••"
                                        Style="width:100%" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => Password)" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeSm="6">
                    <RadzenFormField Text="Confirm password *" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenPassword @bind-Value="ConfirmPassword"
                                        Placeholder="••••••••"
                                        Style="width:100%" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

        </RadzenStack>

        <RadzenStack Gap="1rem">

            <RadzenText TextStyle="TextStyle.Overline" Style="margin:0">
                Personal details
            </RadzenText>

            <RadzenRow Gap="0.75rem">
                <RadzenColumn Size="12" SizeSm="6">
                    <RadzenFormField Text="First name *" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenTextBox @bind-Value="FirstName"
                                       Placeholder="Jane"
                                       Style="width:100%" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => FirstName)" />
                </RadzenColumn>
                <RadzenColumn Size="12" SizeSm="6">
                    <RadzenFormField Text="Last name *" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenTextBox @bind-Value="LastName"
                                       Placeholder="Smith"
                                       Style="width:100%" />
                    </RadzenFormField>
                    <ValidationMessage For="@(() => LastName)" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenFormField Text="Phone number" Variant="Variant.Outlined" Style="width:100%">
                <RadzenTextBox @bind-Value="PhoneNumber"
                               Placeholder="+1 555 000 0000"
                               Style="width:100%" />
            </RadzenFormField>

        </RadzenStack>

        <RadzenStack Gap="1rem">

            <RadzenText TextStyle="TextStyle.Overline" Style="margin:0">
                Business details <RadzenText TagName="TagName.Span" TextStyle="TextStyle.Caption" Style="text-transform:none;opacity:.6"> — optional</RadzenText>
            </RadzenText>

            <RadzenFormField Text="Company" Variant="Variant.Outlined" Style="width:100%">
                <RadzenTextBox @bind-Value="Company"
                               Placeholder="Acme Ltd."
                               Style="width:100%" />
            </RadzenFormField>

            <RadzenFormField Text="Address" Variant="Variant.Outlined" Style="width:100%">
                <RadzenTextBox @bind-Value="Address"
                               Placeholder="123 Main St, City"
                               Style="width:100%" />
            </RadzenFormField>

            <RadzenFormField Text="Tax / Company ID" Variant="Variant.Outlined" Style="width:100%">
                <RadzenTextBox @bind-Value="TaxCode"
                               Placeholder="GB123456789"
                               Style="width:100%" />
            </RadzenFormField>

        </RadzenStack>

        <RadzenButton Text="@(IsLoading ? "Creating account…" : "Create account")"
                      ButtonStyle="ButtonStyle.Primary"
                      Size="ButtonSize.Large"
                      Icon="@(IsLoading ? "" : "person_add")"
                      Disabled="@IsLoading"
                      ButtonType="ButtonType.Submit"
                      Style="width:100%" />

        </EditForm>

        <RadzenText TextStyle="TextStyle.Body2" Style="text-align:center;margin:0">
            Already have an account?
            <RadzenLink Path="/auth/login" Text="Sign in" />
        </RadzenText>

    </RadzenStack>

</RadzenCard>
