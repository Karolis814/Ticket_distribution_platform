@page "/auth/register"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inherits RegisterBase

<PageTitle>Create account</PageTitle>

<RadzenCard Style="max-width:560px;margin:2rem auto;">

    <EditForm EditContext="EditContext" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator/>

        <RadzenStack Gap="1.5rem">

            <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" Style="margin:0">
                Create account
            </RadzenText>

            @if (ErrorMessage is not null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false">
                    @ErrorMessage
                </RadzenAlert>
            }

            <RadzenStack Gap="1rem">

                <RadzenText TextStyle="TextStyle.Overline" Style="margin:0">Account details</RadzenText>

                <RadzenStack Gap="0.25rem">
                    <RadzenFormField Text="Email address *" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenTextBox @bind-Value="Model.Email"
                                       Placeholder="you@example.com"
                                       InputType="InputType.Email"
                                       Style="width:100%"/>
                    </RadzenFormField>
                    <ValidationMessage For="@(() => Model.Email)"/>
                </RadzenStack>

                <RadzenRow Gap="0.75rem">
                    <RadzenColumn Size="12" SizeSm="6">
                        <RadzenStack Gap="0.25rem">
                            <RadzenFormField Text="Password *" Variant="Variant.Outlined" Style="width:100%">
                                <RadzenPassword @bind-Value="Model.Password"
                                                Placeholder="••••••••"
                                                Style="width:100%"/>
                            </RadzenFormField>
                            <ValidationMessage For="@(() => Model.Password)"/>
                        </RadzenStack>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeSm="6">
                        <RadzenFormField Text="Confirm password *" Variant="Variant.Outlined" Style="width:100%">
                            <RadzenPassword @bind-Value="ConfirmPassword"
                                            Placeholder="••••••••"
                                            Style="width:100%"/>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>

            </RadzenStack>

            <RadzenStack Gap="1rem">

                <RadzenText TextStyle="TextStyle.Overline" Style="margin:0">Personal details</RadzenText>

                <RadzenRow Gap="0.75rem">
                    <RadzenColumn Size="12" SizeSm="6">
                        <RadzenStack Gap="0.25rem">
                            <RadzenFormField Text="First name *" Variant="Variant.Outlined" Style="width:100%">
                                <RadzenTextBox @bind-Value="Model.FirstName"
                                               Placeholder="Jane"
                                               Style="width:100%"/>
                            </RadzenFormField>
                            <ValidationMessage For="@(() => Model.FirstName)"/>
                        </RadzenStack>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeSm="6">
                        <RadzenStack Gap="0.25rem">
                            <RadzenFormField Text="Last name *" Variant="Variant.Outlined" Style="width:100%">
                                <RadzenTextBox @bind-Value="Model.LastName"
                                               Placeholder="Smith"
                                               Style="width:100%"/>
                            </RadzenFormField>
                            <ValidationMessage For="@(() => Model.LastName)"/>
                        </RadzenStack>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenFormField Text="Phone number" Variant="Variant.Outlined" Style="width:100%">
                    <RadzenTextBox @bind-Value="Model.PhoneNumber"
                                   Placeholder="+1 555 000 0000"
                                   Style="width:100%"/>
                </RadzenFormField>

            </RadzenStack>

            <RadzenStack Gap="1rem">

                <RadzenText TextStyle="TextStyle.Overline" Style="margin:0">
                    Business details
                    <RadzenText TagName="TagName.Span" TextStyle="TextStyle.Caption" Style="text-transform:none;opacity:.6"> — optional</RadzenText>
                </RadzenText>

                <RadzenFormField Text="Company" Variant="Variant.Outlined" Style="width:100%">
                    <RadzenTextBox @bind-Value="Model.Company" Placeholder="Acme Ltd." Style="width:100%"/>
                </RadzenFormField>

                <RadzenStack Gap="0.25rem">
                    <RadzenLabel Text="Address" Component="Address"/>
                    <RadzenAutoComplete Name="Address"
                                        @bind-Value="Model.Address"
                                        LoadData="@OnLoadAddressData"
                                        Change="@OnAddressSelected"
                                        Data="@AddressSuggestions"
                                        TextProperty="MainText"
                                        ValueProperty="MainText"
                                        Placeholder="Start typing an address…"
                                        IsLoading="@IsSearchingAddress"
                                        Style="display:block;width:100%;"
                                        Multiple="false">
                        <Template Context="prediction">
                            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                                <RadzenText TextStyle="TextStyle.Body2">@(prediction?.MainText ?? "")</RadzenText>
                                @if (!string.IsNullOrEmpty(prediction?.SecondaryText))
                                {
                                    <RadzenText TextStyle="TextStyle.Caption">@prediction.SecondaryText</RadzenText>
                                }
                            </RadzenStack>
                        </Template>
                    </RadzenAutoComplete>
                </RadzenStack>

                <RadzenFormField Text="Tax / Company ID" Variant="Variant.Outlined" Style="width:100%">
                    <RadzenTextBox @bind-Value="Model.TaxCode" Placeholder="GB123456789" Style="width:100%"/>
                </RadzenFormField>

            </RadzenStack>

            <RadzenButton Text="@(IsLoading ? "Creating account…" : "Create account")"
                          ButtonStyle="ButtonStyle.Primary"
                          Size="ButtonSize.Large"
                          Icon="@(IsLoading ? "" : "person_add")"
                          Disabled="@IsLoading"
                          ButtonType="ButtonType.Submit"
                          Style="width:100%"/>

        </RadzenStack>

    </EditForm>

    <RadzenText TextStyle="TextStyle.Body2" Style="text-align:center;margin:1.5rem 0 0">
        Already have an account?
        <RadzenLink Path="/auth/login" Text="Sign in"/>
    </RadzenText>

</RadzenCard>
