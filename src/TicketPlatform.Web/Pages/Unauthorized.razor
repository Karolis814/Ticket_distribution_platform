@page "/unauthorized"
@inject NavigationManager Nav

<PageTitle>Access Denied</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" Class="rz-mt-8">
    <RadzenColumn Size="12" SizeMd="7" SizeLg="5">
        <RadzenCard>
            <RadzenStack Gap="1rem" AlignItems="AlignItems.Center">
                <RadzenText TextStyle="TextStyle.H5">Access Denied</RadzenText>
                <RadzenText>You don't have permission to view this page.</RadzenText>
                <RadzenButton Text="Go to events"
                              ButtonStyle="ButtonStyle.Primary"
                              Click="@(() => Nav.NavigateTo("/events"))" />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
