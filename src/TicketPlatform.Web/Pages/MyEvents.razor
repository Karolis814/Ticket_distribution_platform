@page "/host/events"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inherits MyEventsBase

<PageTitle>My Events</PageTitle>

<RadzenStack Gap="2rem">

    <PageHeader Title="My Events" Subtitle="Manage and track your created events.">
        <Actions>
            <RadzenButton Text="Create Event" Icon="calendar_add_on" ButtonStyle="ButtonStyle.Primary"
                          Size="ButtonSize.Large"
                          Click="@(() => Nav.NavigateTo("/host/create"))"/>
        </Actions>
    </PageHeader>

    @if (!IsLoading && Events.Count > 0)
    {
        <RadzenRow>
            <RadzenColumn Class="rz-col-12 rz-col-md-5">
                <RadzenCard Class="rz-p-4">
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 JustifyContent="JustifyContent.SpaceBetween"
                                 AlignItems="AlignItems.Center"
                                 Class="rz-mb-4">
                        <RadzenText TextStyle="TextStyle.H6" Style="margin:0;">Quick Stats</RadzenText>
                        <RadzenButton Text="Sales Overview" Icon="bar_chart"
                                      ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      Click="@(() => Nav.NavigateTo("/host/sales-overview"))"/>
                    </RadzenStack>
                    <RadzenStack Gap="0">
                        <RadzenStack Orientation="Orientation.Horizontal"
                                     JustifyContent="JustifyContent.SpaceBetween"
                                     AlignItems="AlignItems.Center"
                                     Class="rz-py-3"
                                     Style="border-bottom:1px solid var(--rz-border-disabled-color);">
                            <RadzenText TextStyle="TextStyle.Body2" Style="margin:0;opacity:0.7;">Total Events
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"
                                        Style="margin:0;font-weight:600;">@Events.Count</RadzenText>
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal"
                                     JustifyContent="JustifyContent.SpaceBetween"
                                     AlignItems="AlignItems.Center"
                                     Class="rz-py-3"
                                     Style="border-bottom:1px solid var(--rz-border-disabled-color);">
                            <RadzenText TextStyle="TextStyle.Body2" Style="margin:0;opacity:0.7;">Published</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"
                                        Style="margin:0;font-weight:600;">@Events.Count(e => e.Status == EventStatus.Published)</RadzenText>
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal"
                                     JustifyContent="JustifyContent.SpaceBetween"
                                     AlignItems="AlignItems.Center"
                                     Class="rz-py-3"
                                     Style="border-bottom:1px solid var(--rz-border-disabled-color);">
                            <RadzenText TextStyle="TextStyle.Body2" Style="margin:0;opacity:0.7;">Tickets Sold
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"
                                        Style="margin:0;font-weight:600;">@Events.Sum(e => e.TicketTypes.Sum(t => t.Sold))</RadzenText>
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal"
                                     JustifyContent="JustifyContent.SpaceBetween"
                                     AlignItems="AlignItems.Center"
                                     Class="rz-py-3">
                            <RadzenText TextStyle="TextStyle.Body2" Style="margin:0;opacity:0.7;">Total Capacity
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"
                                        Style="margin:0;font-weight:600;">@Events.Sum(e => e.TicketTypes.Sum(t => t.Quantity))</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
    }
    <EventCards Events="Events"
                IsLoading="IsLoading"
                IsManagementView="true"
                EmptyMessage="You haven't created any events yet."/>

</RadzenStack>
