@page "/events/{EventId:guid}"
@inherits SingleEventBase

<PageTitle>Event Details</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenButton Icon="arrow_back" Text="Back to Events" Click="@(() => NavigationManager.NavigateTo("/events"))" Style="margin-bottom: 1rem;" />

    @if (isLoading)
    {
        <RadzenText>Loading event details...</RadzenText>
    }
    else if (Event is null)
    {
        <RadzenText TextStyle="TextStyle.H5" Text="Event not found." />
    }
    else
    {
        var displayStatus = GetDisplayStatus(Event);

        <RadzenStack Gap="1rem">
            @if (!string.IsNullOrEmpty(Event.ThumbnailUrl))
            {
                <div style="width: 100%; border-radius: 8px; overflow: hidden;">
                    <img src="@Event.ThumbnailUrl" alt="@Event.Title" style="width: 100%; height: auto; display: block; object-fit: cover;" />
                </div>
            }
            else
            {
                <div style="width: 100%; aspect-ratio: 5 / 2; border-radius: 8px; background: linear-gradient(135deg, #3f51b5 0%, #1a237e 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; color: #ffffff; text-align: center;">
                    <div style="font-size: 4rem; font-weight: 700; opacity: 0.9;">Event</div>
                    <div style="font-size: 1.25rem; opacity: 0.75;">Image coming soon</div>
                </div>
            }

            <RadzenText TextStyle="TextStyle.H3" Text="@Event.Title"/>

            <RadzenCard>
                <RadzenStack Gap="1rem">
                    <RadzenText TextStyle="TextStyle.Subtitle1">Event Information</RadzenText>

                    <RadzenRow AlignItems="AlignItems.Center" RowGap="0.5rem">
                        <RadzenColumn Size="12" SizeMD="3" class="rz-text-align-start rz-text-align-md-end">
                            <RadzenText TextStyle="TextStyle.Body2" class="rz-color-tertiary">Category</RadzenText>
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="9">
                            <RadzenBadge Text="@Event.Category" IsPill="true" />
                        </RadzenColumn>
                    </RadzenRow>

                    <RadzenRow AlignItems="AlignItems.Center" RowGap="0.5rem">
                        <RadzenColumn Size="12" SizeMD="3" class="rz-text-align-start rz-text-align-md-end">
                            <RadzenText TextStyle="TextStyle.Body2" class="rz-color-tertiary">Status</RadzenText>
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="9">
                            <RadzenBadge Text="@GetStatusLabel(displayStatus)" IsPill="true" BadgeStyle="@GetStatusBadgeStyle(displayStatus)" />
                        </RadzenColumn>
                    </RadzenRow>

                    <RadzenRow AlignItems="AlignItems.Center" RowGap="0.5rem">
                         <RadzenColumn Size="12" SizeMD="3" class="rz-text-align-start rz-text-align-md-end">
                             <RadzenText TextStyle="TextStyle.Body2" class="rz-color-tertiary">Location</RadzenText>
                         </RadzenColumn>
                         <RadzenColumn Size="12" SizeMD="9">
                             <RadzenText TextStyle="TextStyle.Body1">@(Event.Location ?? "Not specified")</RadzenText>
                         </RadzenColumn>
                     </RadzenRow>

                    <RadzenRow AlignItems="AlignItems.Start" RowGap="0.5rem">
                        <RadzenColumn Size="12" SizeMD="3" class="rz-text-align-start rz-text-align-md-end">
                            <RadzenText TextStyle="TextStyle.Body2" class="rz-color-tertiary">Description</RadzenText>
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="9">
                            <RadzenText TextStyle="TextStyle.Body1" Text="@Event.Description" />
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenStack>
            </RadzenCard>

            @if (Event.Host is not null)
            {
                <RadzenCard>
                    <RadzenStack Gap="0.75rem">
                        <RadzenText TextStyle="TextStyle.Subtitle1">Organized by</RadzenText>

                        <RadzenRow AlignItems="AlignItems.Center" RowGap="0.5rem">
                            <RadzenColumn Size="12" SizeMD="3" class="rz-text-align-start rz-text-align-md-end">
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-color-tertiary">Organizer</RadzenText>
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="9">
                                <RadzenText TextStyle="TextStyle.Body1">@GetHostDisplayName(Event.Host)</RadzenText>
                            </RadzenColumn>
                        </RadzenRow>

                        <RadzenRow AlignItems="AlignItems.Center" RowGap="0.5rem">
                            <RadzenColumn Size="12" SizeMD="3" class="rz-text-align-start rz-text-align-md-end">
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-color-tertiary">Contact</RadzenText>
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="9">
                                <RadzenLink Path="@($"mailto:{Event.Host.Email}")" Text="@Event.Host.Email" />
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenStack>
                </RadzenCard>
            }

            <RadzenCard>
                <RadzenStack Gap="0.75rem" AlignItems="AlignItems.Center">
                    @{
                        var startingFrom = GetStartingFromText(Event);
                    }
                    @if (!string.IsNullOrEmpty(startingFrom))
                    {
                        <RadzenText TextStyle="TextStyle.H5">@startingFrom</RadzenText>
                    }

                    @if (ShouldShowCheckout(Event))
                    {
                        <RadzenButton Click="@(args => NavigationManager.NavigateTo($"/checkout/{Event.Id}"))"
                                      Text="Checkout"
                                      ButtonStyle="ButtonStyle.Success"
                                      Size="ButtonSize.Large"
                                      Icon="shopping_cart" />
                    }
                </RadzenStack>
            </RadzenCard>
        </RadzenStack>
    }
</RadzenStack>
