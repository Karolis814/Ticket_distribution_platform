@page "/auth/forgot-password"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inherits ForgotPasswordBase

<PageTitle>Reset Password</PageTitle>

<RadzenCard Style="width:100%;max-width:420px;margin:2rem auto;">

    <EditForm Model="@Model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator/>

        <RadzenStack Gap="1.5rem">

            <PageHeader Title="Reset Password" Subtitle="Enter your email and we'll send you a reset link."/>

            @if (Message is not null)
            {
                <RadzenAlert AlertStyle="@(AlertStyle.Info)"
                             ShowIcon="true"
                             AllowClose="false">
                    @Message
                </RadzenAlert>
            }

            @if (!IsSubmitted)
            {
                <RadzenStack Gap="0.25rem">
                    <RadzenFormField Text="Email address" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenTextBox @bind-Value="Model.Email"
                                       Placeholder="you@example.com"
                                       InputType="InputType.Email"
                                       Style="width:100%"/>
                    </RadzenFormField>
                    <ValidationMessage For="@(() => Model.Email)"/>
                </RadzenStack>

                <RadzenButton Text="@(IsLoading ? "Sending…" : "Send Reset Link")"
                              ButtonType="ButtonType.Submit"
                              ButtonStyle="ButtonStyle.Primary"
                              Size="ButtonSize.Large"
                              Icon="@(IsLoading ? "" : "send")"
                              Disabled="@IsLoading"
                              Style="width:100%"/>
            }

            <RadzenText TextStyle="TextStyle.Body2" Style="text-align:center;margin:0">
                Remembered it?
                <RadzenLink Path="/auth/login" Text="Sign In"/>
            </RadzenText>

        </RadzenStack>

    </EditForm>

</RadzenCard>
