@page "/host/create"
@page "/host/events/{EventId:guid}/edit"

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inherits CreateEventBase

<EditForm Model="@Model" OnValidSubmit="@OnValidSubmit" OnInvalidSubmit="@OnInvalidSubmit">

    <DataAnnotationsValidator/>
    <RadzenStack Gap="2rem">

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
                     AlignItems="AlignItems.Center" Gap="1rem">
            <PageHeader Title="@(IsEditMode ? "Edit Event" : "Create Event")"
                        Subtitle="@(IsEditMode ? "Update your event details below." : "Fill in the details below to publish your event.")"/>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" AlignItems="AlignItems.Center">
                @if (IsEditMode && !IsCancelled)
                {
                    @if (IsCancelConfirming)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenButton Text="Yes, cancel" ButtonStyle="ButtonStyle.Danger" Icon="event_busy"
                                          Click="@CancelEventAsync" Size="ButtonSize.Large"/>
                            <RadzenButton Text="Keep" ButtonStyle="ButtonStyle.Light"
                                          Click="@(() => IsCancelConfirming = false)" Size="ButtonSize.Large"/>
                        </RadzenStack>
                    }
                    else
                    {
                        <RadzenButton Text="Cancel Event" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Outlined"
                                      Icon="event_busy" Click="@(() => IsCancelConfirming = true)"
                                      Size="ButtonSize.Large"/>
                    }
                }
                <RadzenButton ButtonType="ButtonType.Submit"
                              Text="@(IsEditMode ? "Save Changes" : "Publish")"
                              ButtonStyle="ButtonStyle.Success"
                              Size="ButtonSize.Large"
                              Icon="@(IsEditMode ? "save" : "rocket_launch")"
                              Disabled="@(!IsFormValid || IsCancelled)"/>
            </RadzenStack>
        </RadzenStack>

        @if (IsCancelled)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false">
                This event has been cancelled and cannot be re-published.
            </RadzenAlert>
        }

        <RadzenRow Gap="1.5rem" AlignItems="AlignItems.Stretch">

            <RadzenColumn Size="12" SizeMD="7">
                <RadzenCard Class="rz-overflow-hidden rz-shadow-6" Style="padding:0;height:100%;">
                    <RadzenStack Class="rz-background-color-primary rz-p-3 rz-px-4"
                                 Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem">
                        <RadzenIcon Icon="edit_note" Style="color:white;font-size:1.3rem;"/>
                        <RadzenText TextStyle="TextStyle.Subtitle1" Style="color:white;margin:0;font-weight:600;">Basic Information</RadzenText>
                    </RadzenStack>
                    <RadzenStack Gap="1.25rem" Class="rz-p-4">

                        <RadzenStack Gap="0.25rem">
                            <RadzenFormField Text="Title" Variant="Variant.Outlined" Style="width:100%">
                                <RadzenTextBox Name="Title" @bind-Value="Model.Title" Style="width:100%;"/>
                            </RadzenFormField>
                            <ValidationMessage For="@(() => Model.Title)"/>
                        </RadzenStack>

                        <RadzenStack Gap="0.25rem">
                            <RadzenFormField Text="Category" Variant="Variant.Outlined" Style="width:100%">
                                <RadzenDropDown TValue="EventCategory?" Name="Category"
                                                @bind-Value="Model.Category"
                                                Data="@Categories"
                                                Placeholder="Select a category..."
                                                Style="display:block;width:100%;"/>
                            </RadzenFormField>
                            <ValidationMessage For="@(() => Model.Category)"/>
                        </RadzenStack>

                        <RadzenStack Gap="0.25rem">
                            <RadzenFormField Text="Location" Variant="Variant.Outlined" Style="width:100%">
                                <RadzenAutoComplete Name="Location"
                                                    @bind-Value="Model.Location"
                                                    LoadData="@OnLoadLocationData"
                                                    Change="@OnLocationSelected"
                                                    Data="@LocationSuggestions"
                                                    TextProperty="MainText"
                                                    ValueProperty="MainText"
                                                    Placeholder="Type location to search..."
                                                    Style="display:block;width:100%;"
                                                    IsLoading="@IsSearchingLocations"
                                                    Multiple="false">
                                    <Template Context="prediction">
                                        <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                                            <RadzenText TextStyle="TextStyle.Body2">@(prediction?.MainText ?? "")</RadzenText>
                                            @if (!string.IsNullOrEmpty(prediction?.SecondaryText))
                                            {
                                                <RadzenText TextStyle="TextStyle.Caption">@(prediction?.SecondaryText)</RadzenText>
                                            }
                                        </RadzenStack>
                                    </Template>
                                </RadzenAutoComplete>
                            </RadzenFormField>
                            <ValidationMessage For="@(() => Model.Location)"/>
                        </RadzenStack>

                        <RadzenStack Gap="0.25rem">
                            <RadzenFormField Text="Description" Variant="Variant.Outlined" Style="width:100%">
                                <RadzenTextArea Name="Description" @bind-Value="Model.Description"
                                                Style="display:block;width:100%;height:140px;"/>
                            </RadzenFormField>
                            <ValidationMessage For="@(() => Model.Description)"/>
                        </RadzenStack>

                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="5">
                <RadzenStack Gap="1.5rem">

                    <RadzenCard Class="rz-overflow-hidden rz-shadow-6" Style="padding:0;">
                        <RadzenStack Class="rz-background-color-secondary rz-p-3 rz-px-4"
                                     Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem">
                            <RadzenIcon Icon="calendar_month" Style="color:white;font-size:1.3rem;"/>
                            <RadzenText TextStyle="TextStyle.Subtitle1" Style="color:white;margin:0;font-weight:600;">Schedule</RadzenText>
                        </RadzenStack>
                        <RadzenStack Gap="1rem" Class="rz-p-4">

                            @if (!Model.UseIndividualDates)
                            {
                                <RadzenRow Gap="0.75rem">
                                    <RadzenColumn Size="12" SizeMD="6">
                                        <RadzenFormField Text="Event Starts" Variant="Variant.Outlined" Style="width:100%">
                                            <RadzenDatePicker Name="OccStart"
                                                              @bind-Value="Model.OccurenceStartDate"
                                                              ShowTime="true" DateFormat="yyyy-MM-dd HH:mm"
                                                              HoursStep="1" MinutesStep="15"
                                                              Style="display:block;width:100%;"/>
                                        </RadzenFormField>
                                    </RadzenColumn>
                                    <RadzenColumn Size="12" SizeMD="6">
                                        <RadzenFormField Text="Event Ends" Variant="Variant.Outlined" Style="width:100%">
                                            <RadzenDatePicker Name="OccEnd"
                                                              @bind-Value="Model.OccurenceEndDate"
                                                              ShowTime="true" DateFormat="yyyy-MM-dd HH:mm"
                                                              HoursStep="1" MinutesStep="15"
                                                              Style="display:block;width:100%;"/>
                                        </RadzenFormField>
                                    </RadzenColumn>
                                </RadzenRow>
                            }

                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                <RadzenCheckBox @bind-Value="Model.UseIndividualDates" TValue="bool" Name="UseIndividualDates"/>
                                <RadzenLabel Text="Use individual dates per ticket release" Component="UseIndividualDates"/>
                            </RadzenStack>

                        </RadzenStack>
                    </RadzenCard>

                    <RadzenCard Class="rz-overflow-hidden rz-shadow-6" Style="padding:0;">
                        <RadzenStack Class="rz-background-color-info rz-p-3 rz-px-4"
                                     Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem">
                            <RadzenIcon Icon="image" Style="color:white;font-size:1.3rem;"/>
                            <RadzenText TextStyle="TextStyle.Subtitle1" Style="color:white;margin:0;font-weight:600;">Event Poster</RadzenText>
                        </RadzenStack>
                        <RadzenStack Gap="0.75rem" Class="rz-p-4">

                            <label for="posterUpload" style="cursor:pointer;display:block;">
                                @if (IsUploadingImage)
                                {
                                    <RadzenStack Style="min-height:280px;"
                                                 Class="rz-border-radius-4 rz-border"
                                                 AlignItems="AlignItems.Center"
                                                 JustifyContent="JustifyContent.Center"
                                                 Gap="1rem">
                                        <RadzenProgressBarCircular ShowValue="false"
                                                                   Mode="ProgressBarMode.Indeterminate"
                                                                   Size="ProgressBarCircularSize.Medium"/>
                                        <RadzenText TextStyle="TextStyle.Caption">Uploading…</RadzenText>
                                    </RadzenStack>
                                }
                                else if (string.IsNullOrEmpty(Model.ThumbnailUrl))
                                {
                                    <RadzenStack Style="min-height:280px;border:2px dashed var(--rz-primary);"
                                                 Class="rz-border-radius-4"
                                                 AlignItems="AlignItems.Center"
                                                 JustifyContent="JustifyContent.Center"
                                                 Gap="0.75rem">
                                        <div style="width:64px;height:64px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:2px solid var(--rz-primary);">
                                            <RadzenIcon Icon="cloud_upload" Style="color:var(--rz-primary);font-size:2rem;"/>
                                        </div>
                                        <RadzenStack Gap="0.2rem" AlignItems="AlignItems.Center">
                                            <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-primary);font-weight:600;">Click to upload</RadzenText>
                                            <RadzenText TextStyle="TextStyle.Caption">Max 10 MB · Recommended size: 1280×720</RadzenText>
                                        </RadzenStack>
                                    </RadzenStack>
                                }
                                else
                                {
                                    <div style="position:relative;" class="rz-border-radius-4 rz-overflow-hidden">
                                        <RadzenImage Path="@Model.ThumbnailUrl"
                                                     Style="width:100%;display:block;aspect-ratio:16/9;object-fit:cover;"/>
                                        <RadzenStack Orientation="Orientation.Horizontal"
                                                     AlignItems="AlignItems.Center"
                                                     JustifyContent="JustifyContent.Center"
                                                     Gap="0.25rem"
                                                     Style="position:absolute;bottom:0;left:0;right:0;padding:0.5rem;background:rgba(0,0,0,0.6);">
                                            <RadzenIcon Icon="edit" Style="color:white;font-size:1rem;"/>
                                            <RadzenText TextStyle="TextStyle.Caption" Style="color:white;">Click to change</RadzenText>
                                        </RadzenStack>
                                    </div>
                                }
                            </label>
                            <InputFile id="posterUpload" style="display:none" OnChange="@OnFileChange"
                                       accept="image/jpeg,image/png,image/webp,image/heic,image/heif"/>

                        </RadzenStack>
                    </RadzenCard>

                </RadzenStack>
            </RadzenColumn>

        </RadzenRow>

        <!-- Ticket Releases -->
        <RadzenStack Gap="1.25rem">

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                <RadzenIcon Icon="confirmation_number" Style="color:var(--rz-success);font-size:1.75rem;"/>
                <RadzenStack Gap="0.1rem">
                    <RadzenText TextStyle="TextStyle.H6" Style="margin:0;">Ticket Releases</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption">Add one or more releases with different prices and dates</RadzenText>
                </RadzenStack>
            </RadzenStack>

            <RadzenRow Gap="1.25rem">
            @for (int i = 0; i < Model.TicketReleases.Count; i++)
            {
                int currentIndex = i;
                <RadzenColumn Size="12" SizeMD="6">
                <RadzenCard Class="rz-overflow-hidden rz-shadow-6" Style="padding:0;">

                    <RadzenStack Class="rz-background-color-success rz-p-3 rz-px-4"
                                 Orientation="Orientation.Horizontal"
                                 AlignItems="AlignItems.Center"
                                 JustifyContent="JustifyContent.SpaceBetween">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                            <div style="width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <span style="color:white;font-weight:700;font-size:0.8rem;">@(currentIndex + 1)</span>
                            </div>
                            <RadzenText TextStyle="TextStyle.Subtitle1" Style="color:white;margin:0;font-weight:600;">
                                @(string.IsNullOrWhiteSpace(Model.TicketReleases[currentIndex].Title)
                                    ? $"Release {currentIndex + 1}"
                                    : Model.TicketReleases[currentIndex].Title)
                            </RadzenText>
                        </RadzenStack>
                        @if (Model.TicketReleases.Count > 1)
                        {
                            <RadzenButton Click="@(() => RemoveTicketRelease(currentIndex))"
                                          ButtonStyle="ButtonStyle.Light"
                                          Variant="Variant.Text"
                                          Size="ButtonSize.Small"
                                          Icon="delete_outline"/>
                        }
                    </RadzenStack>

                    <RadzenStack Gap="1.25rem" Class="rz-p-4">

                        <RadzenStack Gap="0.25rem">
                            <RadzenFormField Text="Release Title" Variant="Variant.Outlined" Style="width:100%">
                                <RadzenTextBox Name="@($"Title_{currentIndex}")"
                                               @bind-Value="Model.TicketReleases[currentIndex].Title"
                                               Style="width:100%;"/>
                            </RadzenFormField>
                            <ValidationMessage For="@(() => Model.TicketReleases[currentIndex].Title)"/>
                        </RadzenStack>

                        <RadzenRow Gap="0.75rem">
                            <RadzenColumn Size="5">
                                <RadzenStack Gap="0.25rem">
                                    <RadzenFormField Text="Price" Variant="Variant.Outlined" Style="width:100%">
                                        <RadzenNumeric TValue="decimal"
                                                       Format="0.00" Min="0" Step="0.01" ShowUpDown="false"
                                                       Name="@($"Price_{currentIndex}")"
                                                       Placeholder="0.00"
                                                       @bind-Value="Model.TicketReleases[currentIndex].Price"
                                                       Style="display:block;width:100%;"/>
                                    </RadzenFormField>
                                    <ValidationMessage For="@(() => Model.TicketReleases[currentIndex].Price)"/>
                                </RadzenStack>
                            </RadzenColumn>
                            <RadzenColumn Size="3">
                                <RadzenStack Gap="0.25rem">
                                    <RadzenFormField Text="Currency" Variant="Variant.Outlined" Style="width:100%">
                                        <RadzenDropDown TValue="string"
                                                        Name="@($"Currency_{currentIndex}")"
                                                        Value="@Model.TicketReleases[currentIndex].Currency"
                                                        Change="@(v => SyncCurrency((string)v))"
                                                        Data="@Currencies"
                                                        Style="display:block;width:100%;"/>
                                    </RadzenFormField>
                                    <ValidationMessage For="@(() => Model.TicketReleases[currentIndex].Currency)"/>
                                </RadzenStack>
                            </RadzenColumn>
                            <RadzenColumn Size="4">
                                <RadzenStack Gap="0.25rem">
                                    <RadzenFormField Text="Quantity" Variant="Variant.Outlined" Style="width:100%">
                                        <RadzenNumeric TValue="int"
                                                       Name="@($"Qty_{currentIndex}")"
                                                       @bind-Value="Model.TicketReleases[currentIndex].Quantity"
                                                       Style="display:block;width:100%;"/>
                                    </RadzenFormField>
                                    <ValidationMessage For="@(() => Model.TicketReleases[currentIndex].Quantity)"/>
                                </RadzenStack>
                            </RadzenColumn>
                        </RadzenRow>

                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenCheckBox Name="@($"UseMaxUses_{currentIndex}")"
                                            @bind-Value="Model.TicketReleases[currentIndex].UseMaxUses"
                                            TValue="bool"/>
                            <RadzenLabel Text="Ticket can be used more than once"
                                         Component="@($"UseMaxUses_{currentIndex}")"/>
                        </RadzenStack>

                        @if (Model.TicketReleases[currentIndex].UseMaxUses)
                        {
                            <RadzenStack Gap="0.25rem" Style="max-width:180px;">
                                <RadzenFormField Text="Uses per ticket" Variant="Variant.Outlined" Style="width:100%">
                                    <RadzenNumeric TValue="int"
                                                   Name="@($"MaxUses_{currentIndex}")"
                                                   Min="2"
                                                   @bind-Value="Model.TicketReleases[currentIndex].MaxUses"
                                                   Style="display:block;width:100%;"/>
                                </RadzenFormField>
                                <ValidationMessage For="@(() => Model.TicketReleases[currentIndex].MaxUses)"/>
                            </RadzenStack>
                        }

                        @if (Model.UseIndividualDates)
                        {
                            <hr class="rz-my-0"/>
                            <RadzenRow Gap="0.75rem">
                                <RadzenColumn Size="12" SizeMD="6">
                                    <RadzenStack Gap="0.25rem">
                                        <RadzenFormField Text="Event Starts" Variant="Variant.Outlined" Style="width:100%">
                                            <RadzenDatePicker Name="@($"OccStart_{currentIndex}")"
                                                              @bind-Value="Model.TicketReleases[currentIndex].OccurenceStartDate"
                                                              ShowTime="true" DateFormat="yyyy-MM-dd HH:mm"
                                                              HoursStep="1" MinutesStep="15"
                                                              Style="display:block;width:100%;"/>
                                        </RadzenFormField>
                                        <ValidationMessage For="@(() => Model.TicketReleases[currentIndex].OccurenceStartDate)"/>
                                    </RadzenStack>
                                </RadzenColumn>
                                <RadzenColumn Size="12" SizeMD="6">
                                    <RadzenStack Gap="0.25rem">
                                        <RadzenFormField Text="Event Ends" Variant="Variant.Outlined" Style="width:100%">
                                            <RadzenDatePicker Name="@($"OccEnd_{currentIndex}")"
                                                              @bind-Value="Model.TicketReleases[currentIndex].OccurenceEndDate"
                                                              ShowTime="true" DateFormat="yyyy-MM-dd HH:mm"
                                                              HoursStep="1" MinutesStep="15"
                                                              Style="display:block;width:100%;"/>
                                        </RadzenFormField>
                                        <ValidationMessage For="@(() => Model.TicketReleases[currentIndex].OccurenceEndDate)"/>
                                    </RadzenStack>
                                </RadzenColumn>
                            </RadzenRow>
                        }

                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenCheckBox Name="@($"CustomAdm_{currentIndex}")"
                                            @bind-Value="Model.TicketReleases[currentIndex].UseCustomAdmissionTimes"
                                            TValue="bool"/>
                            <RadzenLabel Text="Set a different admission window"
                                         Component="@($"CustomAdm_{currentIndex}")"/>
                        </RadzenStack>

                        @if (Model.TicketReleases[currentIndex].UseCustomAdmissionTimes)
                        {
                            <RadzenRow Gap="0.75rem">
                                <RadzenColumn Size="12" SizeMD="6">
                                    <RadzenStack Gap="0.25rem">
                                        <RadzenFormField Text="Admission Opens" Variant="Variant.Outlined" Style="width:100%">
                                            <RadzenDatePicker Name="@($"AdmStart_{currentIndex}")"
                                                              @bind-Value="Model.TicketReleases[currentIndex].AdmissionStartDate"
                                                              ShowTime="true" DateFormat="yyyy-MM-dd HH:mm"
                                                              HoursStep="1" MinutesStep="15"
                                                              Style="display:block;width:100%;"/>
                                        </RadzenFormField>
                                        <ValidationMessage For="@(() => Model.TicketReleases[currentIndex].AdmissionStartDate)"/>
                                    </RadzenStack>
                                </RadzenColumn>
                                <RadzenColumn Size="12" SizeMD="6">
                                    <RadzenStack Gap="0.25rem">
                                        <RadzenFormField Text="Admission Closes" Variant="Variant.Outlined" Style="width:100%">
                                            <RadzenDatePicker Name="@($"AdmEnd_{currentIndex}")"
                                                              @bind-Value="Model.TicketReleases[currentIndex].AdmissionEndDate"
                                                              ShowTime="true" DateFormat="yyyy-MM-dd HH:mm"
                                                              HoursStep="1" MinutesStep="15"
                                                              Style="display:block;width:100%;"/>
                                        </RadzenFormField>
                                        <ValidationMessage For="@(() => Model.TicketReleases[currentIndex].AdmissionEndDate)"/>
                                    </RadzenStack>
                                </RadzenColumn>
                            </RadzenRow>
                        }

                    </RadzenStack>
                </RadzenCard>
                </RadzenColumn>
            }
            </RadzenRow>

            <RadzenStack AlignItems="AlignItems.Center" Class="rz-py-2">
                <RadzenButton Click="@AddTicketRelease"
                              ButtonStyle="ButtonStyle.Secondary"
                              Icon="add"
                              Text="Add Another Release"
                              Style="min-width:260px;"/>
            </RadzenStack>

        </RadzenStack>

    </RadzenStack>

</EditForm>
