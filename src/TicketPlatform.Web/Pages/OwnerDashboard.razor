@page "/host/sales-overview"

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Host")]
@inherits OwnerDashboardBase

<PageTitle>Sales Overview</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center">
    <RadzenColumn Size="12" SizeLg="10">
        <RadzenStack Gap="1.5rem">

            <PageHeader Title="Sales Overview" Subtitle="Track revenue, ticket sales, and payouts." />

            @if (Loading)
            {
                <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height:300px;">
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"/>
                </RadzenStack>
            }
            else if (!string.IsNullOrWhiteSpace(Error))
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">
                    @Error
                </RadzenAlert>
            }
            else if (Dashboard is not null)
            {
                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMd="3">
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.Overline">Sold tickets</RadzenText>
                            <RadzenText TextStyle="TextStyle.H4" Style="font-weight:700">
                                @Dashboard.SoldTickets
                            </RadzenText>
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMd="3">
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.Overline">Gross revenue</RadzenText>
                            @foreach (var amount in Dashboard.GrossRevenue)
                            {
                                <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700">
                                    @FormatMoney(amount)
                                </RadzenText>
                            }
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMd="3">
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.Overline">Platform fees</RadzenText>
                            @foreach (var amount in Dashboard.PlatformFees)
                            {
                                <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700">
                                    @FormatMoney(amount)
                                </RadzenText>
                            }
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMd="3">
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.Overline">Net revenue</RadzenText>
                            @foreach (var amount in Dashboard.NetRevenue)
                            {
                                <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700">
                                    @FormatMoney(amount)
                                </RadzenText>
                            }
                        </RadzenCard>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMd="6">
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700">
                                Available Stripe balance
                            </RadzenText>

                            @if (Dashboard.StripeAvailableBalance.Count == 0)
                            {
                                <RadzenText>No balance available</RadzenText>
                            }
                            else
                            {
                                @foreach (var amount in Dashboard.StripeAvailableBalance)
                                {
                                    <RadzenText TextStyle="TextStyle.H5">
                                        @FormatMoney(amount)
                                    </RadzenText>
                                }
                            }
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMd="6">
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700">
                                Pending Stripe balance
                            </RadzenText>

                            @if (Dashboard.StripePendingBalance.Count == 0)
                            {
                                <RadzenText>No pending balance</RadzenText>
                            }
                            else
                            {
                                @foreach (var amount in Dashboard.StripePendingBalance)
                                {
                                    <RadzenText TextStyle="TextStyle.H5">
                                        @FormatMoney(amount)
                                    </RadzenText>
                                }
                            }
                        </RadzenCard>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenCard>
                    <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700">
                        Ticket analytics
                    </RadzenText>

                    <RadzenRow Gap="1rem" Class="rz-mt-3">
                        <RadzenColumn Size="12" SizeMd="4">
                            <RadzenCard Variant="Variant.Flat">
                                <RadzenText TextStyle="TextStyle.Overline">Used tickets</RadzenText>
                                <RadzenText TextStyle="TextStyle.H4" Style="font-weight:700">
                                    @Dashboard.UsedTickets
                                </RadzenText>
                            </RadzenCard>
                        </RadzenColumn>

                        <RadzenColumn Size="12" SizeMd="4">
                            <RadzenCard Variant="Variant.Flat">
                                <RadzenText TextStyle="TextStyle.Overline">Valid tickets</RadzenText>
                                <RadzenText TextStyle="TextStyle.H4" Style="font-weight:700">
                                    @Dashboard.ValidTickets
                                </RadzenText>
                            </RadzenCard>
                        </RadzenColumn>

                        <RadzenColumn Size="12" SizeMd="4">
                            <RadzenCard Variant="Variant.Flat">
                                <RadzenText TextStyle="TextStyle.Overline">Invalid tickets</RadzenText>
                                <RadzenText TextStyle="TextStyle.H4" Style="font-weight:700">
                                    @Dashboard.InvalidTickets
                                </RadzenText>
                            </RadzenCard>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenCard>

                <RadzenCard>
                    <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700">
                        Revenue by event
                    </RadzenText>

                    @if (Dashboard.RevenueByEvent.Count == 0)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Class="rz-mt-3">
                            No revenue yet.
                        </RadzenAlert>
                    }
                    else
                    {
                        <RadzenDataGrid Data="@Dashboard.RevenueByEvent"
                                        TItem="EventRevenueDto"
                                        Class="rz-mt-3">
                            <Columns>
                                <RadzenDataGridColumn TItem="EventRevenueDto"
                                                      Property="EventName"
                                                      Title="Event"/>

                                <RadzenDataGridColumn TItem="EventRevenueDto"
                                                      Property="TicketsSold"
                                                      Title="Tickets sold"/>

                                <RadzenDataGridColumn TItem="EventRevenueDto"
                                                      Title="Revenue">
                                    <Template Context="eventRevenue">
                                        @FormatMoney(new MoneyAmountDto(
                                            eventRevenue.RevenueCents,
                                            eventRevenue.Currency))
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    }
                </RadzenCard>

                <RadzenCard>
                    <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700">
                        Daily sales
                    </RadzenText>

                    @if (Dashboard.DailySales.Count == 0)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Class="rz-mt-3">
                            No daily sales yet.
                        </RadzenAlert>
                    }
                    else
                    {
                        <RadzenDataGrid Data="@Dashboard.DailySales"
                                        TItem="DailySalesDto"
                                        Class="rz-mt-3">
                            <Columns>
                                <RadzenDataGridColumn TItem="DailySalesDto"
                                                      Property="Date"
                                                      Title="Date"/>

                                <RadzenDataGridColumn TItem="DailySalesDto"
                                                      Property="TicketsSold"
                                                      Title="Tickets sold"/>

                                <RadzenDataGridColumn TItem="DailySalesDto"
                                                      Title="Revenue">
                                    <Template Context="sale">
                                        @FormatMoney(new MoneyAmountDto(
                                            sale.RevenueCents,
                                            sale.Currency))
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    }
                </RadzenCard>

                <RadzenCard>
                    <RadzenStack Gap="1rem">
                        <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700">
                            Payout history
                        </RadzenText>

                        @if (Dashboard.Payouts.Count == 0)
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
                                No payouts yet.
                            </RadzenAlert>
                        }
                        else
                        {
                            <RadzenDataGrid Data="@Dashboard.Payouts" TItem="StripePayoutDto">
                                <Columns>
                                    <RadzenDataGridColumn TItem="StripePayoutDto"
                                                          Property="Id"
                                                          Title="Payout ID"/>

                                    <RadzenDataGridColumn TItem="StripePayoutDto"
                                                          Title="Amount">
                                        <Template Context="payout">
                                            @FormatMoney(new MoneyAmountDto(
                                                payout.AmountCents,
                                                payout.Currency))
                                        </Template>
                                    </RadzenDataGridColumn>

                                    <RadzenDataGridColumn TItem="StripePayoutDto"
                                                          Title="Status">
                                        <Template Context="payout">
                                            @if (payout.Status == "paid")
                                            {
                                                <RadzenBadge Text="PAID"
                                                             BadgeStyle="BadgeStyle.Success"/>
                                            }
                                            else if (payout.Status == "pending")
                                            {
                                                <RadzenBadge Text="PENDING"
                                                             BadgeStyle="BadgeStyle.Warning"/>
                                            }
                                            else
                                            {
                                                <RadzenBadge Text="@payout.Status.ToUpper()"
                                                             BadgeStyle="BadgeStyle.Danger"/>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>

                                    <RadzenDataGridColumn TItem="StripePayoutDto"
                                                          Title="Created">
                                        <Template Context="payout">
                                            @payout.Created.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        }
                    </RadzenStack>
                </RadzenCard>

                <RadzenButton Text="Back to settings"
                              Icon="arrow_back"
                              ButtonStyle="ButtonStyle.Light"
                              Click="@(() => Nav.NavigateTo("/user/settings"))"
                              Style="width:100%"/>
            }

        </RadzenStack>
    </RadzenColumn>
</RadzenRow>

