@inherits MainLayoutBase

<RadzenComponents/>

<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal"
                     AlignItems="AlignItems.Center"
                     Gap="0"
                     class="rz-h-100">
            <RadzenSidebarToggle Click="@ToggleSidebar"/>
            <RadzenLabel Text="Ticket Platform" class="rz-px-3"/>
        </RadzenStack>
    </RadzenHeader>
    <RadzenSidebar @bind-Expanded="@SidebarExpanded">
        <NavMenu/>
    </RadzenSidebar>
    <RadzenBody>
        <RadzenStack class="rz-p-4">
            <div style="max-width:760px;margin:0 auto;width:100%;">
                @Body
            </div>
        </RadzenStack>
    </RadzenBody>
</RadzenLayout>
