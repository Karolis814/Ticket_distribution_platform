{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=ticket_platform;Username=ticket_user;Password=ticket_pass"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:7174",
      "http://localhost:5174"
    ]
  },
  "ClientBaseUrl": "https://localhost:7174",
  "Stripe": {
    "PlatformFeePercent": 5
  },
  "Audit": {
    "InterceptBusinessLogic": true
  },
  "Places": {
    "Provider": "Google"
  },
  "Caching": {
    "EventsCache": {
      "Enabled": true
    }
  },
  "GooglePlaces": {
    "ApiKey": ""
  },
  "BlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ThumbnailsContainer": "event-thumbnails",
    "MaxImageBytes": 5242880
  },
  "JwtSettings": {
  "Secret": "your-super-secret-key-min-32-chars!!",
  "Issuer": "TicketPlatform",
  "Audience": "TicketPlatform",
  "AccessTokenExpiryMinutes": 15,
  "RefreshTokenExpiryDays": 7
 }
}
